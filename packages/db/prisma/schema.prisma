generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  binaryTargets   = ["native", "rhel-openssl-3.0.x"]
  output          = "../../../apps/web/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["isysocial"]
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  CLIENTE
  SOPORTE
  FACTURACION

  @@schema("isysocial")
}

enum TokenType {
  INVITATION
  PASSWORD_RESET

  @@schema("isysocial")
}

enum NotificationType {
  POST_SUBMITTED_FOR_REVIEW
  POST_APPROVED
  POST_CHANGES_REQUESTED
  POST_REVISION_LIMIT_REACHED
  NEW_POST_COMMENT
  NEW_IDEA_COMMENT
  POST_SCHEDULED
  IDEA_CONVERTED_TO_POST

  @@schema("isysocial")
}

enum SocialNetwork {
  FACEBOOK
  INSTAGRAM
  LINKEDIN
  TIKTOK
  X

  @@schema("isysocial")
}

enum PostType {
  IMAGE
  CAROUSEL
  STORY
  REEL
  VIDEO
  TEXT

  @@schema("isysocial")
}

enum PostStatus {
  DRAFT
  IN_REVIEW
  CLIENT_CHANGES
  APPROVED
  SCHEDULED
  PUBLISHED
  PAUSED
  CANCELLED

  @@schema("isysocial")
}

enum IdeaStatus {
  BACKLOG
  IN_PROGRESS
  READY
  CONVERTED
  DISCARDED

  @@schema("isysocial")
}

enum PublishStatus {
  PENDING
  SUCCESS
  FAILED

  @@schema("isysocial")
}

enum ContactRole {
  APPROVER   // Puede aprobar / rechazar posts
  REVIEWER   // Puede ver y comentar, pero no aprobar
  OBSERVER   // Solo lectura

  @@schema("isysocial")
}

// ─── AGENCY (multi-tenant) ────────────────────────────────────────────────────

model Agency {
  id           String    @id @default(cuid())
  name         String
  slug         String    @unique
  logoUrl      String?
  logoDarkUrl  String?
  primaryColor String?   @default("#2563eb")
  accentColor  String?
  maxClients   Int       @default(20)
  maxEditors   Int       @default(10)
  planTier     String    @default("trial")
  trialEndsAt  DateTime?
  timezone     String    @default("America/Mexico_City")
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // AI credits
  aiCreditsUsed   Int       @default(0)
  aiCreditsLimit  Int       @default(1000)
  aiCreditResetAt DateTime?

  users          User[]
  clients        ClientProfile[]
  clientGroups   ClientGroup[]
  posts          Post[]
  ideas          Idea[]
  categories     PostCategory[]
  templates      PostTemplate[]
  socialAccounts AgencySocialAccount[]

  @@map("iso_agencies")
  @@schema("isysocial")
}

// ─── AGENCY SOCIAL ACCOUNTS ──────────────────────────────────────────────────

model AgencySocialAccount {
  id       String @id @default(cuid())
  agencyId String
  agency   Agency @relation(fields: [agencyId], references: [id], onDelete: Cascade)

  network     SocialNetwork
  accountName String
  accountId   String // Platform account ID (Page ID for FB, IG business account ID)
  profilePic  String?
  pageId      String? // Facebook Page ID (for publishing)

  accessToken    String    @db.Text
  refreshToken   String?   @db.Text
  tokenExpiresAt DateTime?
  tokenScope     String?

  isActive    Boolean  @default(true)
  connectedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  publishLogs         PostPublishLog[]
  clientNetworkLinks  ClientSocialNetwork[]

  @@unique([agencyId, network, accountId])
  @@index([agencyId])
  @@map("iso_agency_social_accounts")
  @@schema("isysocial")
}

// ─── CLIENT GROUPS ────────────────────────────────────────────────────────────

model ClientGroup {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  name      String
  color     String   @default("#6B7280")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clients ClientProfile[]

  @@index([agencyId])
  @@map("iso_client_groups")
  @@schema("isysocial")
}

// ─── USERS & AUTH ─────────────────────────────────────────────────────────────

model User {
  id                  String   @id @default(cuid())
  email               String   @unique
  passwordHash        String?
  name                String
  phone               String?
  avatarUrl           String?
  role                Role
  isActive            Boolean  @default(true)
  onboardingCompleted Boolean  @default(false)
  fcmTokens           String[] @default([])
  agencyId            String?
  agency              Agency?  @relation(fields: [agencyId], references: [id])
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  clientProfile   ClientProfile?
  clientContact   ClientContact?
  editorProfile   EditorProfile?
  notifications   Notification[]
  tokens          Token[]
  postComments    PostComment[]
  ideaComments    IdeaComment[]
  videoComments   VideoComment[]  @relation("VideoCommentAuthor")
  postStatusLogs  PostStatusLog[]
  postRevisions   PostRevision[]
  ideas           Idea[]          @relation("UserIdeas")
  publishLogs     PostPublishLog[]
  mediaVersions   PostMediaVersion[]

  @@map("iso_users")
  @@schema("isysocial")
}

model ClientProfile {
  id          String       @id @default(cuid())
  userId      String       @unique
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agencyId    String
  agency      Agency       @relation(fields: [agencyId], references: [id])
  groupId     String?
  group       ClientGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  companyName String
  logoUrl     String?
  brandColors Json?
  brandKit    Json? // { primaryColor, secondaryColor, accentColor, typography, toneOfVoice, styleNotes }
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  socialNetworks         ClientSocialNetwork[]
  editorAssignments      EditorClientAssignment[]
  posts                  Post[]
  ideas                  Idea[]
  brandAssets            ClientBrandAsset[]
  guidedReviewSessions   GuidedReviewSession[]
  brandBrochureSessions  BrandBrochureSession[]
  contacts               ClientContact[]
  dayThemes              ClientDayTheme[]

  @@index([agencyId])
  @@index([groupId])
  @@map("iso_client_profiles")
  @@schema("isysocial")
}

// ─── CLIENT DAY THEMES (temas por día de la semana por cliente) ───────────────

model ClientDayTheme {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)
  dayOfWeek       Int           // 0=Domingo, 1=Lunes, ..., 6=Sábado
  theme           String        // e.g. "Sabías qué...?", "Lifestyle"
  emoji           String?       // optional emoji for the theme
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([clientProfileId, dayOfWeek])
  @@index([clientProfileId])
  @@map("iso_client_day_themes")
  @@schema("isysocial")
}

// ─── CLIENT CONTACTS (múltiples revisores por cliente) ────────────────────────

model ClientContact {
  id              String        @id @default(cuid())
  clientProfileId String
  clientProfile   ClientProfile @relation(fields: [clientProfileId], references: [id], onDelete: Cascade)

  // Cada contacto tiene su propio User para login independiente
  userId          String        @unique
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  role            ContactRole   @default(REVIEWER)
  isActive        Boolean       @default(true)
  invitedAt       DateTime      @default(now())
  lastLoginAt     DateTime?

  @@index([clientProfileId])
  @@map("iso_client_contacts")
  @@schema("isysocial")
}

model EditorProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissions Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignedClients EditorClientAssignment[]

  @@map("iso_editor_profiles")
  @@schema("isysocial")
}

model EditorClientAssignment {
  id        String        @id @default(cuid())
  editorId  String
  editor    EditorProfile @relation(fields: [editorId], references: [id], onDelete: Cascade)
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdAt DateTime      @default(now())

  @@unique([editorId, clientId])
  @@map("iso_editor_client_assignments")
  @@schema("isysocial")
}

model ClientSocialNetwork {
  id          String        @id @default(cuid())
  clientId    String
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  network     SocialNetwork
  pageId      String?       // Platform page ID (FB page ID, IG business ID, etc.)
  accountName String?
  profilePic  String?
  isActive    Boolean       @default(true)
  createdAt   DateTime      @default(now())

  // Source: Can be direct OAuth or inherited from agency
  sourceType      String        @default("agency")  // "agency" or "direct"
  agencyAccountId String?
  agencyAccount   AgencySocialAccount? @relation(fields: [agencyAccountId], references: [id], onDelete: SetNull)

  // OAuth connection fields (copy from agency account if inherited)
  accessToken    String?
  refreshToken   String?
  tokenExpiresAt DateTime?
  accountId      String? // Platform user/page ID needed for API calls
  tokenScope     String? // Granted OAuth scopes (comma-separated)
  assignedAt     DateTime @default(now())

  publishLogs PostPublishLog[]

  @@unique([clientId, network, pageId]) // Allow multiple pages per network
  @@index([clientId])
  @@index([agencyAccountId])
  @@map("iso_client_social_networks")
  @@schema("isysocial")
}

// ─── POSTS ────────────────────────────────────────────────────────────────────

model Post {
  id       String        @id @default(cuid())
  agencyId String
  agency   Agency        @relation(fields: [agencyId], references: [id])
  clientId String
  client   ClientProfile @relation(fields: [clientId], references: [id])
  editorId String?

  title    String?
  copy     String?
  hashtags String?
  network  SocialNetwork
  postType PostType

  status      PostStatus @default(DRAFT)
  scheduledAt DateTime?
  publishedAt DateTime?

  revisionsUsed            Int     @default(0)
  revisionsLimit           Int     @default(3)
  hasRequestedGuidedReview Boolean @default(false)
  referenceLink            String?
  storyData                Json?
  storyBatchId             String?
  storySequence            Int?     @default(0)

  categoryId    String?
  category      PostCategory? @relation(fields: [categoryId], references: [id])
  mirrorGroupId String?

  // Cross-app: Isytask integration (optional link to a Task)
  isytaskTaskId String?   // ID of the linked Task in public schema

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media              PostMedia[]
  comments           PostComment[]
  statusLogs         PostStatusLog[]
  revisions          PostRevision[]
  publishLogs        PostPublishLog[]
  guidedReviewSession GuidedReviewSession?

  @@index([agencyId, clientId])
  @@index([agencyId, status])
  @@index([scheduledAt])
  @@index([mirrorGroupId])
  @@index([isytaskTaskId])
  @@map("iso_posts")
  @@schema("isysocial")
}

model PostMedia {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  storagePath String
  mimeType    String
  fileSize    Int
  sortOrder   Int      @default(0)
  thumbnailUrl String?  // URL to generated thumbnail (for videos)
  duration     Float?   // Duration in seconds (for videos)
  createdAt   DateTime @default(now())

  versions PostMediaVersion[]

  @@map("iso_post_media")
  @@schema("isysocial")
}

// ─── POST MEDIA VERSIONS (Image history before/after) ────────────────────────

model PostMediaVersion {
  id          String    @id @default(cuid())
  mediaId     String
  media       PostMedia @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  versionNumber Int
  fileUrl       String
  storagePath   String
  mimeType      String
  fileSize      Int

  // Attribution
  changedById String
  changedBy   User   @relation(fields: [changedById], references: [id])
  changeNotes String? // "Aumentar contraste", "Ajustar saturación"

  // Link to the comment that requested changes
  relatedCommentId String?
  relatedComment   PostComment? @relation(fields: [relatedCommentId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@unique([mediaId, versionNumber])
  @@index([mediaId])
  @@map("iso_post_media_versions")
  @@schema("isysocial")
}

model PostComment {
  id         String   @id @default(cuid())
  postId     String
  post       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId   String
  author     User     @relation(fields: [authorId], references: [id])
  content    String
  isInternal Boolean  @default(false)
  isResolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  mediaVersions PostMediaVersion[]

  @@map("iso_post_comments")
  @@schema("isysocial")
}

model PostStatusLog {
  id          String      @id @default(cuid())
  postId      String
  post        Post        @relation(fields: [postId], references: [id], onDelete: Cascade)
  fromStatus  PostStatus?
  toStatus    PostStatus
  changedById String
  changedBy   User        @relation(fields: [changedById], references: [id])
  note        String?
  changedAt   DateTime    @default(now())

  @@map("iso_post_status_logs")
  @@schema("isysocial")
}

model PostRevision {
  id          String   @id @default(cuid())
  postId      String
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  version     Int
  title       String?
  copy        String?
  hashtags    String?
  changedById String
  changedBy   User     @relation(fields: [changedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([postId])
  @@map("iso_post_revisions")
  @@schema("isysocial")
}

model PostPublishLog {
  id             String              @id @default(cuid())
  postId         String
  post           Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  networkId      String?
  socialNetwork  ClientSocialNetwork? @relation(fields: [networkId], references: [id], onDelete: Cascade)
  agencyAccountId String?
  agencyAccount   AgencySocialAccount? @relation(fields: [agencyAccountId], references: [id], onDelete: Cascade)
  network        SocialNetwork
  platformPostId String? // ID returned by the platform (FB post ID, tweet ID, etc.)
  platformUrl    String? // URL to the published post on the platform
  status         PublishStatus       @default(PENDING)
  errorMessage   String?
  requestedById  String
  requestedBy    User                @relation(fields: [requestedById], references: [id])
  attemptedAt    DateTime            @default(now())
  publishedAt    DateTime?

  @@index([postId])
  @@map("iso_post_publish_logs")
  @@schema("isysocial")
}

// ─── GUIDED REVIEW SESSIONS ──────────────────────────────────────────────────

model GuidedReviewSession {
  id        String @id @default(cuid())
  postId    String @unique
  post      Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  requestedAt DateTime  @default(now())
  scheduledAt DateTime?
  completedAt DateTime?

  status      String    @default("PENDING") // PENDING, SCHEDULED, COMPLETED, CANCELLED
  notes       String?   @db.Text

  createdBy   String
  confirmedBy String?

  @@index([postId])
  @@index([clientId])
  @@index([status])
  @@map("iso_guided_review_sessions")
  @@schema("isysocial")
}

// ─── IDEAS / BLUEPRINT ────────────────────────────────────────────────────────

model Idea {
  id          String         @id @default(cuid())
  agencyId    String
  agency      Agency         @relation(fields: [agencyId], references: [id])
  clientId    String?
  client      ClientProfile? @relation(fields: [clientId], references: [id])
  createdById String?
  createdBy   User?          @relation("UserIdeas", fields: [createdById], references: [id])

  title           String
  description     String?
  copyIdeas       String?
  network         SocialNetwork?
  networks        SocialNetwork[]  @default([])
  postType        PostType?
  tentativeDate   DateTime?
  status          IdeaStatus     @default(BACKLOG)
  convertedPostId String?
  isClientIdea    Boolean        @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  media    IdeaMedia[]
  links    IdeaLink[]
  comments IdeaComment[]

  @@index([agencyId, clientId])
  @@map("iso_ideas")
  @@schema("isysocial")
}

model IdeaMedia {
  id          String   @id @default(cuid())
  ideaId      String
  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  storagePath String
  mimeType    String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  @@map("iso_idea_media")
  @@schema("isysocial")
}

model IdeaLink {
  id            String   @id @default(cuid())
  ideaId        String
  idea          Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  url           String
  ogTitle       String?
  ogImage       String?
  ogDescription String?
  createdAt     DateTime @default(now())

  @@map("iso_idea_links")
  @@schema("isysocial")
}

model IdeaComment {
  id        String   @id @default(cuid())
  ideaId    String
  idea      Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id])
  content   String
  createdAt DateTime @default(now())

  @@map("iso_idea_comments")
  @@schema("isysocial")
}

// ─── POST TEMPLATES ─────────────────────────────────────────────────────────

model PostTemplate {
  id           String         @id @default(cuid())
  agencyId     String
  agency       Agency         @relation(fields: [agencyId], references: [id])
  name         String
  description  String?
  copyTemplate String?
  hashtags     String?
  network      SocialNetwork?
  postType     PostType?
  categoryId   String?
  category     PostCategory?  @relation(fields: [categoryId], references: [id])
  usageCount   Int            @default(0)
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  media TemplateMedia[]

  @@index([agencyId])
  @@map("iso_post_templates")
  @@schema("isysocial")
}

model TemplateMedia {
  id          String       @id @default(cuid())
  templateId  String
  template    PostTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  fileName    String
  fileUrl     String
  storagePath String
  mimeType    String
  fileSize    Int          @default(0)
  sortOrder   Int          @default(0)
  createdAt   DateTime     @default(now())

  @@map("iso_template_media")
  @@schema("isysocial")
}

// ─── POST CATEGORIES ─────────────────────────────────────────────────────────

model PostCategory {
  id        String   @id @default(cuid())
  agencyId  String
  agency    Agency   @relation(fields: [agencyId], references: [id])
  name      String
  color     String // hex "#FF5722"
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  posts     Post[]
  templates PostTemplate[]

  @@unique([agencyId, name])
  @@index([agencyId])
  @@map("iso_post_categories")
  @@schema("isysocial")
}

// ─── CLIENT BRAND ASSETS ─────────────────────────────────────────────────────

model ClientBrandAsset {
  id          String        @id @default(cuid())
  clientId    String
  client      ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)
  label       String
  fileName    String
  fileUrl     String
  storagePath String
  mimeType    String
  fileSize    Int
  sortOrder   Int           @default(0)
  createdAt   DateTime      @default(now())

  @@index([clientId])
  @@map("iso_client_brand_assets")
  @@schema("isysocial")
}

// ─── NOTIFICATIONS & SYSTEM ───────────────────────────────────────────────────

model Notification {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id])
  type        NotificationType
  title       String
  body        String
  isRead      Boolean          @default(false)
  relatedId   String?
  relatedType String?
  createdAt   DateTime         @default(now())

  @@index([userId, isRead])
  @@map("iso_notifications")
  @@schema("isysocial")
}

model Token {
  id        String    @id @default(cuid())
  token     String    @unique
  type      TokenType
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@map("iso_tokens")
  @@schema("isysocial")
}

// ─── BRAND BROCHURE (Guided AI questionnaire) ──────────────────────────────────

model BrandBrochureSession {
  id        String @id @default(cuid())
  clientId  String
  client    ClientProfile @relation(fields: [clientId], references: [id], onDelete: Cascade)

  status      String  @default("INITIAL")  // INITIAL, IN_PROGRESS, COMPLETED, ABANDONED
  currentStep Int     @default(1)

  // Responses from client
  responses Json @default("{}")  // { questionId: answer }

  // Generated fields by AI
  generatedFieldSchema Json?  // { fields: [...], metadata: {...} }

  // Final brand kit merge
  finalBrandKit Json?

  initiatedAt DateTime @default(now())
  completedAt DateTime?

  questions BrandBrochureQuestion[]
  fields    BrandBrochureField[]
  uploads   BrandBrochureUpload[]

  @@unique([clientId])
  @@index([clientId])
  @@map("iso_brand_brochure_sessions")
  @@schema("isysocial")
}

model BrandBrochureQuestion {
  id        String @id @default(cuid())
  sessionId String
  session   BrandBrochureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  stepNumber  Int
  questionId  String         // "company_desc", "industry", "target_audience", etc.
  question    String
  inputType   String         @default("textarea")  // textarea, text, select, multi-select, color, file
  hint        String?
  required    Boolean        @default(true)

  response     String?
  responseJson Json?          // For complex inputs (files, multiple values)

  aiGenerated Boolean @default(false)
  createdAt   DateTime @default(now())

  @@unique([sessionId, questionId])
  @@index([sessionId])
  @@map("iso_brand_brochure_questions")
  @@schema("isysocial")
}

model BrandBrochureField {
  id        String @id @default(cuid())
  sessionId String
  session   BrandBrochureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  fieldId   String       // "missionStatement", "brandColors", "targetAudience", etc.
  label     String
  category  String       // "communication", "identity", "strategy", "assets"

  suggestedValue String?  // AI-generated suggestion
  clientValue    String?  // Client's edited/approved value
  confidence     Float?   // AI confidence score (0-1)

  relatedQuestions String[]  // Which questions informed this field

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([sessionId, fieldId])
  @@index([sessionId])
  @@map("iso_brand_brochure_fields")
  @@schema("isysocial")
}

model BrandBrochureUpload {
  id        String @id @default(cuid())
  sessionId String
  session   BrandBrochureSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  fileName         String
  fileUrl          String
  storagePath      String
  mimeType         String
  fileSize         Int              @default(0)
  extractedText    String?          // Raw text from extraction
  extractionMethod String           @default("manual") // "ocr_vision" | "pdf_parse" | "manual"
  confidence       Float?           // Extraction confidence 0-1

  uploadedAt DateTime @default(now())

  @@index([sessionId])
  @@map("iso_brand_brochure_uploads")
  @@schema("isysocial")
}

// ─── VIDEO COMMENTS (Timeline feedback on videos) ──────────────────────────
model VideoComment {
  id              String   @id @default(cuid())

  // Polymorphic relationship: links to either PostMedia or TaskFile
  mediaType       String   // "POST_MEDIA" | "TASK_FILE"
  mediaId         String   // Foreign key (flexible: can reference PostMedia.id or TaskFile.id)

  // Comment data
  authorId        String
  author          User     @relation("VideoCommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  content         String

  // CRITICAL: Timestamp field for video timeline feedback
  timecodeSeconds Float?   // Seconds into video (e.g., 15.5 = 15.5 seconds)

  // Metadata
  isInternal      Boolean  @default(false)
  isResolved      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mediaId, timecodeSeconds])
  @@map("iso_video_comments")
  @@schema("isysocial")
}

model SystemConfig {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt

  @@map("iso_system_config")
  @@schema("isysocial")
}

// ─── REALTIME EVENTS (SSE event bus for cache invalidation) ──────────────────
// Server writes events here after mutations; SSE endpoint polls and pushes to clients.
// Events auto-expire — only ~5 min of history needed for delivery.
model RealtimeEvent {
  id        String   @id @default(cuid())
  agencyId  String
  type      String   // POST_CREATED | POST_UPDATED | POST_STATUS_CHANGED | COMMENT_ADDED | POST_PUBLISHED | CALENDAR_UPDATED | IDEA_UPDATED
  postId    String?  // target post (for targeted invalidation)
  clientId  String?  // target client
  payload   Json?    // extra context if needed
  createdAt DateTime @default(now())

  @@index([agencyId, createdAt])
  @@map("iso_realtime_events")
  @@schema("isysocial")
}
